{
  "info": {
    "name": "meetZen API",
    "description": "Source-of-truth Postman collection for the latest backend endpoints.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "_postman_id": "a73f2c8e-c32b-4cb0-a0f1-b7d7cd2f31f9"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "item": [
    {
      "name": "Users",
      "item": [
        {
          "name": "List Users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Returns all users."
          }
        },
        {
          "name": "Create User",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Leandro Silva\",\n  \"email\": \"leandro@meetzen.com\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users"
              ]
            },
            "description": "Creates a new user."
          }
        },
        {
          "name": "Get First User",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/users/first",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "users",
                "first"
              ]
            },
            "description": "Returns the first user or 404 when there are no users."
          }
        },
        {
          "name": "Who Am I",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/whoami",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "whoami"
              ]
            },
            "description": "Returns backend instance info (instance and port) for load-balancer verification."
          }
        }
      ]
    }
  ]
}
